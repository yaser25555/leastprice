rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email == 'yaser.haroon79@gmail.com';
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ad_banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /popular_products/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /system_health/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /search_requests/{documentId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, create, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
  }
}
