rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email == 'yaser.haroon79@gmail.com';
    }

    function isMarketingManager() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRole == 'marketing_manager';
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ad_banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /exclusive_deals/{dealId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isMarketingManager();
    }

    match /comparison_search_cache/{documentId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /popular_products/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /system_health/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /search_requests/{documentId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        !('adminRole' in request.resource.data) &&
        !('planActivated' in request.resource.data) &&
        !('planStatus' in request.resource.data)
      );
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.adminRole == resource.data.adminRole &&
        request.resource.data.planActivated == resource.data.planActivated &&
        request.resource.data.planStatus == resource.data.planStatus
      );
      allow delete: if isAdmin();
    }
  }
}
